# ============================================
# 构建产物和编译输出
# ============================================
build/
bin/
*.o
*.so
*.a
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
CTestTestfile.cmake

# ============================================
# 配置文件（包含敏感信息，严禁提交）
# ============================================
# 忽略所有实际的配置文件
**/config.ini
**/*.ini
!/**/*.ini.template
**/config.json
**/*.json
!/**/*.json.template
# 但保留模板文件
!**/config.ini.template
!**/config.json.template

# ============================================
# IDE 和编辑器文件
# ============================================
.vscode/
.vs/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# Visual Studio 项目文件
# ============================================
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
x64/
Debug/
Release/
ipch/

# ============================================
# Node.js 相关（VerifyServer）
# ============================================
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# 日志和运行时文件
# ============================================
*.log
*.pid
*.dump
core.*

